FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . ./

# Build TypeScript
RUN npm run build

# Expose port
EXPOSE 3001

# Set environment variable for database path
ENV DB_PATH=/app/data/vouchers.db

# Create data directory for SQLite database
RUN mkdir -p /app/data

# Start the application
CMD ["npm", "start"]
